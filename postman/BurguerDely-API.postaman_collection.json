                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-009 — Atualizar perfil",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/auth/profile/{{user_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste Atualizado\",\n  \"city\": \"Brasília\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Nome atualizado', () => {",
                  "  pm.expect(pm.response.json().user.name).to.eql('Teste Atualizado');",
                  "});",
                  "pm.test('Cidade atualizada', () => {",
                  "  pm.expect(pm.response.json().user.city).to.eql('Brasília');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-010 — Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Logout realizado', () => {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "TC-API-011 — Criar pedido",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"items\": [\n    { \"id\": \"1\", \"name\": \"Burger Clássico\", \"price\": 28.90, \"quantity\": 2, \"image\": \"\" }\n  ],\n  \"total\": 57.80,\n  \"address\": \"QNG 04 Casa 06, Taguatinga, DF\",\n  \"paymentMethod\": \"cartao\",\n  \"deliveryLat\": -15.82,\n  \"deliveryLng\": -48.05\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna id do pedido', () => pm.expect(pm.response.json().id).to.be.a('string'));",
                  "pm.test('Status inicial é confirmed', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('confirmed');",
                  "});",
                  "pm.test('Total correto', () => pm.expect(pm.response.json().total).to.eql(57.80));",
                  "pm.test('Tem tempo estimado', () => {",
                  "  pm.expect(pm.response.json().estimatedMinutes).to.be.above(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set('order_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-012 — Criar pedido sem campos obrigatórios (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Retorna mensagem de erro', () => pm.expect(pm.response.json().error).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-013 — Buscar pedido por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/orders/{{order_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('ID confere', () => {",
                  "  pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('order_id'));",
                  "});",
                  "pm.test('Tem items', () => pm.expect(pm.response.json().items).to.be.an('array'));",
                  "pm.test('Tem endereço', () => pm.expect(pm.response.json().address).to.be.a('string'));"
                ]
              }
            }
          ]
        },
