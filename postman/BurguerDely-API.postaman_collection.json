{
  "info": {
    "name": "BurguerDely API Tests",
    "_postman_id": "burgerdely-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "reset_code", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "TC-API-001 — Registrar novo usuário",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste User\",\n  \"email\": \"teste@burgerdely.com\",\n  \"password\": \"Senha@123\",\n  \"address\": \"QNG 04 Casa 06\",\n  \"city\": \"Taguatinga\",\n  \"state\": \"DF\",\n  \"zipCode\": \"72130040\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Retorna user com id', () => pm.expect(pm.response.json().user).to.have.property('id'));",
                  "pm.test('Retorna token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.test('Não retorna senha', () => pm.expect(pm.response.json().user).to.not.have.property('password'));",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.token);",
                  "pm.collectionVariables.set('user_id', data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-002 — Registrar e-mail duplicado (409)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicado\",\n  \"email\": \"teste@burgerdely.com\",\n  \"password\": \"Senha@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Retorna erro de e-mail duplicado', () => {",
                  "  pm.expect(pm.response.json().error).to.include('cadastrado');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-003 — Registro sem campos obrigatórios (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Retorna success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-004 — Login com credenciais válidas",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teste@burgerdely.com\",\n  \"password\": \"Senha@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Retorna token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.test('Retorna user com email', () => {",
                  "  pm.expect(pm.response.json().user.email).to.eql('teste@burgerdely.com');",
                  "});",
                  "",
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-005 — Login com senha inválida (401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
