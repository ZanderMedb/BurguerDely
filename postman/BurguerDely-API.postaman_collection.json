                  "pm.test('Mensagem de sucesso', () => {",
                  "  pm.expect(pm.response.json().message).to.include('sucesso');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-API-008 — Login com nova senha",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teste@burgerdely.com\",\n  \"password\": \"NovaSenha@456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
